# .env.example
# Ampalone Partner Portal - Environment Configuration
# Copy this file to .env and update with your values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME=Ampalone Partner Portal
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL=postgresql://admin:your_password@localhost:5432/ampalone_portal
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===========================================
# SECURITY SETTINGS
# ===========================================
# Generate secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8

# ===========================================
# PARTNER PROGRAM SETTINGS
# ===========================================
DEFAULT_PARTNER_MARGIN=25.0
MAX_DISCOUNT_WITHOUT_APPROVAL=60.0
MIN_COMMISSION_PAYOUT=25000.0
COMMISSION_PAYOUT_DAYS=30

# ===========================================
# FILE UPLOAD SETTINGS
# ===========================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_DOCUMENT_TYPES=.pdf,.doc,.docx

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@ampalone.com
EMAIL_SUPPORT=support@ampalone.com
EMAIL_LEGAL=legal@ampalone.com

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# COMPANY DETAILS (INDIA)
# ===========================================
COMPANY_CIN=U72200KA2020PTC134567
COMPANY_GST=29AAAAA0000A1Z5
COMPANY_ADDRESS=Bangalore, Karnataka, India
COMPANY_PHONE=+91-80-XXXX-XXXX

# ===========================================
# CORS SETTINGS
# ===========================================
CORS_ORIGINS=https://www.ampalone.com,https://portal.ampalone.com,http://localhost:3000

# ===========================================
# API SETTINGS
# ===========================================
API_V1_PREFIX=/api/v1
RATE_LIMIT_PER_MINUTE=100
